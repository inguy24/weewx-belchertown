        buttonText = defaultSelection.displayName;
    }
    
    var html = '<div class="date-range-dropdown-group">';
    html += '<div class="dropdown">';
    html += '<button class="btn btn-default dropdown-toggle" type="button" ';
    html += 'id="' + buttonId + '" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">';
    html += buttonText + ' <span class="caret"></span>';
    html += '</button>';
    html += '<ul class="dropdown-menu" aria-labelledby="' + buttonId + '" id="' + dropdownId + '">';
    
    // REMOVED: "All Data" option - no longer needed
    
    if (rollingRanges.length > 0) {
        // Sort rolling ranges by period (shortest to longest)
        var sortedRolling = rollingRanges.sort(function(a, b) {
            var aNum = parseInt(a.period.replace('d', ''));
            var bNum = parseInt(b.period.replace('d', ''));
            return aNum - bNum;
        });
        
        sortedRolling.forEach(function(range) {
            html += '<li><a href="#" class="date-range-option" ';
            html += 'data-filename="' + range.filename + '" ';
            html += 'data-display-name="' + range.displayName + '" ';
            html += 'data-group-name="' + groupName + '" ';
            html += 'data-container-id="' + containerId + '">';
