/**
 * Phase 2.1: Date Range File Detection Functions
 * Belchertown Date Range Dropdowns - Frontend Integration
 * 
 * This code integrates with the existing Belchertown chart system to detect
 * and organize available date range JSON files based on graphs.json configuration.
 * 
 * Integration Instructions:
 * - Add this code to belchertown.js.tmpl (recommend after line 50, before jQuery document ready)
 * - The functions will work with the existing showChart() function
 * - No modifications needed to existing chart rendering logic
 */

// Global variable to cache graphs.json configuration
var belchertown_graphs_config = null;
var belchertown_daterange_groups = new Map();

/**
 * Load and parse graphs.json to identify chart groups with date range functionality
 * This function should be called once during page initialization
 * @returns {Promise<boolean>} Success status
 */
#raw
/**
 * Load and parse graphs.json to identify chart groups with date range functionality
 * Now waits for async file checking to complete
 * @returns {Promise<boolean>} Success status
 */
async function loadDateRangeConfiguration() {
    try {
        // Use existing get_relative_url() function from Belchertown
        var response = await fetch(get_relative_url() + '/json/graphs.json');
        if (!response.ok) {
            throw new Error('Failed to load graphs.json: ' + response.status);
        }
        
        belchertown_graphs_config = await response.json();
        await scanForDateRangeGroups(); // Now await the async scanning
        
        belchertown_debug("Date Range Detection: Successfully loaded graphs.json configuration and validated file existence");
        return true;
        
    } catch (error) {
        belchertown_debug("Date Range Detection: Failed to load configuration - " + error.message);
        return false;
    }
}

/**
 * Scan graphs.json for chart groups with date range functionality enabled
 * Now handles async file checking
 * Populates the global belchertown_daterange_groups Map
 */
async function scanForDateRangeGroups() {
    if (!belchertown_graphs_config) {
        belchertown_debug("Date Range Detection: No graphs configuration loaded");
        return;
    }

    belchertown_daterange_groups.clear();

    var groupProcessing = [];

    for (var groupName in belchertown_graphs_config) {
        if (belchertown_graphs_config.hasOwnProperty(groupName)) {
            var groupConfig = belchertown_graphs_config[groupName];
            
            // Skip top-level configuration properties (colors, tooltip_date_format, etc.)
            if (typeof groupConfig !== 'object' || groupConfig === null) {
                continue;
            }
            
            // Check if this group has date ranges enabled
            if (groupConfig.enable_date_ranges === 'true' || groupConfig.enable_date_ranges === true) {
                groupProcessing.push(
                    buildDateRangeFileList(groupName, groupConfig).then(function(dateRangeInfo) {
                        belchertown_daterange_groups.set(dateRangeInfo.groupName, dateRangeInfo);
                        belchertown_debug("Date Range Detection: Found enabled group '" + dateRangeInfo.groupName + "' with " + dateRangeInfo.allFiles.length + " available files");
                    })
                );
            }
        }
    }

    // Wait for all groups to be processed in parallel
    await Promise.all(groupProcessing);
    
    belchertown_debug("Date Range Detection: Found " + belchertown_daterange_groups.size + " chart groups with date range functionality");
}

/**
 * Build the list of available date range files for a specific chart group
 * Now checks file existence before adding to dropdown options
 * @param {string} groupName - The chart group name
 * @param {object} groupConfig - The group configuration from graphs.json
 * @returns {Promise<object>} Organized date range file information
 */
async function buildDateRangeFileList(groupName, groupConfig) {
    var dateRangeInfo = {
        groupName: groupName,
        title: groupConfig.title || groupName,
        baseFile: groupName + '.json',
        rollingRanges: [],
        yearlyRanges: [],
        monthlyRanges: [],
        allFiles: []
    };

    // Add base file (default/all data) - assume this always exists
    dateRangeInfo.allFiles.push({
        type: 'base',
        filename: dateRangeInfo.baseFile,
        displayName: 'All Data',
        sortOrder: 0,
        period: null,
        year: null,
        month: null
    });

    // Collect all potential files to check in parallel
    var filesToCheck = [];
    var fileInfos = [];

    // Process rolling ranges (7d, 30d, etc.)
    if (groupConfig.rolling_ranges && Array.isArray(groupConfig.rolling_ranges)) {
        groupConfig.rolling_ranges.forEach(function(range, index) {
            var filename = groupName + '_' + range + '.json';
            var fileInfo = {
                type: 'rolling',
                period: range,
                filename: filename,
                displayName: formatRollingDisplayName(range),
                sortOrder: 10 + index,
                year: null,
                month: null
            };
            
            filesToCheck.push(filename);
            fileInfos.push(fileInfo);
        });
    }

    // Process yearly ranges
    if (groupConfig.available_years && Array.isArray(groupConfig.available_years)) {
        groupConfig.available_years.forEach(function(year, index) {
            var filename = groupName + '_' + year + '.json';
            var fileInfo = {
                type: 'yearly',
                year: year,
                filename: filename,
                displayName: year.toString(),
                sortOrder: 100 + index,
                period: null,
                month: null
            };
            
            filesToCheck.push(filename);
            fileInfos.push(fileInfo);
        });
    }

    // Process monthly ranges (if enabled)
    if (groupConfig.enable_monthly_breakdown === 'true' || groupConfig.enable_monthly_breakdown === true) {
        if (groupConfig.available_years && Array.isArray(groupConfig.available_years)) {
            var monthSortOrder = 200;
            groupConfig.available_years.forEach(function(year) {
                // Generate months 01-12 for each available year
                for (var month = 1; month <= 12; month++) {
                    var monthStr = month.toString().padStart(2, '0');
                    var filename = groupName + '_' + year + '-' + monthStr + '.json';
                    var fileInfo = {
                        type: 'monthly',
                        year: year,
                        month: monthStr,
                        filename: filename,
                        displayName: formatMonthlyDisplayName(year, monthStr),
                        sortOrder: monthSortOrder++,
                        period: null
                    };
                    
                    filesToCheck.push(filename);
                    fileInfos.push(fileInfo);
                }
            });
        }
    }

    // Check all files in parallel for maximum performance
    belchertown_debug("Date Range Detection: Checking " + filesToCheck.length + " potential files for " + groupName);
    
    var existenceChecks = filesToCheck.map(function(filename) {
        return checkFileExists(filename);
    });
    var existenceResults = await Promise.all(existenceChecks);

    // Add only files that actually exist
    var filesFound = 0;
    for (var i = 0; i < filesToCheck.length; i++) {
        if (existenceResults[i]) {
            var fileInfo = fileInfos[i];
            
            // Add to appropriate category
            if (fileInfo.type === 'rolling') {
                dateRangeInfo.rollingRanges.push(fileInfo);
            } else if (fileInfo.type === 'yearly') {
                dateRangeInfo.yearlyRanges.push(fileInfo);
            } else if (fileInfo.type === 'monthly') {
                dateRangeInfo.monthlyRanges.push(fileInfo);
            }
            
            dateRangeInfo.allFiles.push(fileInfo);
            filesFound++;
        } else {
            belchertown_debug("Date Range Detection: Skipping non-existent file: " + filesToCheck[i]);
        }
    }

    // Sort all files by sortOrder for consistent display
    dateRangeInfo.allFiles.sort(function(a, b) {
        return a.sortOrder - b.sortOrder;
    });
    
    belchertown_debug("Date Range Detection: Found " + filesFound + " existing files out of " + filesToCheck.length + " potential files for " + groupName);
    
    return dateRangeInfo;
}

/**
 * Format rolling range periods for display
 * @param {string} range - Rolling range period (e.g., "7d", "30d")
 * @returns {string} Formatted display name
 */
function formatRollingDisplayName(range) {
    const rangeMap = {
        '7d': 'Last 7 Days',
        '30d': 'Last 30 Days',
        '60d': 'Last 60 Days',
        '90d': 'Last 90 Days',
        '1d': 'Last 24 Hours',
        '14d': 'Last 2 Weeks',
        '365d': 'Last Year'
    };
    
    // Return mapped value or create a default
    return rangeMap[range] || 'Last ' + range.replace('d', ' Days');
}

/**
 * Format monthly periods for display
 * @param {string} year - Year
 * @param {string} month - Month (01-12)
 * @returns {string} Formatted display name
 */
function formatMonthlyDisplayName(year, month) {
    const monthNames = [
        'January', 'February', 'March', 'April', 'May', 'June',
        'July', 'August', 'September', 'October', 'November', 'December'
    ];
    
    const monthIndex = parseInt(month) - 1;
    return monthNames[monthIndex] + ' ' + year;
}

/**
 * Check if a JSON file exists asynchronously
 * @param {string} filename - The filename to check (e.g., "test_ranges_2024-01.json")
 * @returns {Promise<boolean>} True if file exists and is accessible
 */
async function checkFileExists(filename) {
    try {
        var response = await fetch(get_relative_url() + '/json/' + filename);
        return response.ok; // true if 200-299 status code
    } catch (error) {
        return false; // File doesn't exist or network error
    }
}

/**
 * Check if a specific chart group has date range functionality enabled
 * @param {string} groupName - The chart group name to check
 * @returns {boolean} True if date ranges are enabled for this group
 */
function isDateRangeEnabled(groupName) {
    return belchertown_daterange_groups.has(groupName);
}

/**
 * Get date range information for a specific chart group
 * @param {string} groupName - The chart group name
 * @returns {object|null} Date range info object or null if not enabled
 */
function getDateRangeInfo(groupName) {
    return belchertown_daterange_groups.get(groupName) || null;
}

/**
 * Get all chart groups that have date range functionality enabled
 * @returns {Array} Array of group names with date range functionality
 */
function getDateRangeEnabledGroups() {
    var groups = [];
    belchertown_daterange_groups.forEach(function(value, key) {
        groups.push(key);
    });
    return groups;
}

/**
 * Get available files for a specific chart group, organized by type
 * @param {string} groupName - The chart group name
 * @returns {object|null} Object with categorized file lists or null if not enabled
 */
function getAvailableFiles(groupName) {
    const info = belchertown_daterange_groups.get(groupName);
    if (!info) return null;
    
    return {
        all: info.allFiles,
        base: info.allFiles.filter(f => f.type === 'base'),
        rolling: info.rollingRanges,
        yearly: info.yearlyRanges,
        monthly: info.monthlyRanges
    };
}

