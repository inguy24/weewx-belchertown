/**
 * Utility function to get the base chart group name from a date range filename
 * @param {string} filename - Date range filename (e.g., "test_ranges_7d.json")
 * @returns {string} Base group name (e.g., "test_ranges")
 */
function getBaseGroupName(filename) {
    // Remove .json extension if present
    const baseName = filename.replace('.json', '');
    
    // Split on underscore and try to identify the base name
    const parts = baseName.split('_');
    if (parts.length <= 1) return baseName;
    
    // Check if last part looks like a date range (7d, 30d, 2024, 2024-01, etc.)
    const lastPart = parts[parts.length - 1];
    if (/^\d+d$/.test(lastPart) || /^\d{4}$/.test(lastPart) || /^\d{4}-\d{2}$/.test(lastPart)) {
        // Remove the date range part and rejoin
        return parts.slice(0, -1).join('_');
    }
    
    return baseName;
}


