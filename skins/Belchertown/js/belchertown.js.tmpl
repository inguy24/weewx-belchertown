/**
 * Create Months dropdown with year/month selection
 * @param {Array} monthlyRanges - Array of monthly range objects
 * @param {string} groupName - Chart group name
 * @param {string} containerId - Container ID
 * @returns {string} HTML for months dropdown
 */
function createMonthsDropdown(monthlyRanges, groupName, containerId, defaultSelection) {
    var dropdownId = 'months-' + containerId;
    var buttonId = 'months-btn-' + containerId;
    
    // Determine button text - show default if monthly is the default type
    var buttonText = 'Months';
    if (defaultSelection && defaultSelection.type === 'monthly') {
        buttonText = defaultSelection.displayName;
    }
    
    var html = '<div class="date-range-dropdown-group">';
    html += '<div class="dropdown">';
    html += '<button class="btn btn-default dropdown-toggle" type="button" ';
    html += 'id="' + buttonId + '" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">';
    html += buttonText + ' <span class="caret"></span>';
    html += '</button>';
    html += '<ul class="dropdown-menu dropdown-menu-months" aria-labelledby="' + buttonId + '" id="' + dropdownId + '">';
    
    // REMOVED: "All Data" option - no longer needed
    
    // Create organized month options by year
    var monthsByYear = {};
    monthlyRanges.forEach(function(monthRange) {
        if (!monthsByYear[monthRange.year]) {
            monthsByYear[monthRange.year] = [];
        }
        monthsByYear[monthRange.year].push(monthRange);
    });
    
    // Sort years descending (newest first)
    var years = Object.keys(monthsByYear).sort(function(a, b) {
        return parseInt(b) - parseInt(a);
    });
    
    // Create options organized by year
    years.forEach(function(year, yearIndex) {
        if (yearIndex > 0) {
            html += '<li role="separator" class="divider"></li>';
        }
        
        // Year header
        html += '<li class="dropdown-header">' + year + '</li>';
        
        // Sort months within year (newest first - December to January)
        var yearMonths = monthsByYear[year].sort(function(a, b) {
            return parseInt(b.month) - parseInt(a.month);
        });
        
        // Add month options for this year
        yearMonths.forEach(function(monthRange) {
            html += '<li><a href="#" class="date-range-option month-option" ';
            html += 'data-filename="' + monthRange.filename + '" ';
            html += 'data-display-name="' + monthRange.displayName + '" ';
            html += 'data-group-name="' + groupName + '" ';
            html += 'data-container-id="' + containerId + '">';
            html += monthRange.displayName + '</a></li>';
        });
    });
    
    html += '</ul></div></div>';
    return html;
}


