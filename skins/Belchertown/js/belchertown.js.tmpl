            }

            // Show the forecasts rows
            if (forecast_interval == "forecast_1hr") {
                jQuery(".1hr_forecasts").html(output_html);
                belchertown_debug("html_1hr: " + output_html);
            } else if (forecast_interval == "forecast_3hr") {
