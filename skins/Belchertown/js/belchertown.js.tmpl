/**
 * FIXED: Enhanced initialization to only process enabled groups for appropriate pages
 * This is the COMPLETE initializeDateRangeDropdowns() function with home page fix
 */
function initializeDateRangeDropdowns() {
    // CRITICAL: Only get groups that actually have date ranges enabled
    var enabledGroups = getDateRangeEnabledGroups();
    
    if (enabledGroups.length === 0) {
        belchertown_debug("Date Range UI: No chart groups have date range functionality enabled");
        return;
    }
    
    belchertown_debug("Date Range UI: Initializing dropdowns for " + enabledGroups.length + " enabled groups: " + enabledGroups.join(', '));
    
    // Get current page context - check URL parameter FIRST
    var currentPageGraph = 'unknown';
    var urlGraph = getURLvar('graph');
    
    if (urlGraph) {
        currentPageGraph = urlGraph;
        belchertown_debug("Date Range UI: Detected individual page from URL: " + currentPageGraph);
    } else if (pageName) {
        currentPageGraph = pageName.replace('.html', '');
        belchertown_debug("Date Range UI: Detected page from pageName: " + currentPageGraph);
    } else if (typeof graph !== 'undefined' && graph) {
        currentPageGraph = graph;
        belchertown_debug("Date Range UI: Detected page from graph variable: " + currentPageGraph);
    } else {
        currentPageGraph = 'unknown';
        belchertown_debug("Date Range UI: Could not detect page context");
    }
    
    // FIXED: Only process groups that are actually enabled AND relevant for current page
    for (var i = 0; i < enabledGroups.length; i++) {
        var groupName = enabledGroups[i];
        
        // Double-check this group is actually enabled (paranoid check)
        if (!isDateRangeEnabled(groupName)) {
            belchertown_debug("Date Range UI: Skipping " + groupName + " - not actually enabled");
            continue;
        }
        
        // CRITICAL: Determine if this group is relevant for the current page
        var shouldProcessGroup = false;
        
        // THE ?graph=all FIX: This line was changed from "if (urlGraph)" to "if (urlGraph && urlGraph !== 'all')"
        if (urlGraph && urlGraph !== 'all') {
            // Individual chart group page: ONLY process the group that matches the URL parameter
            if (urlGraph === groupName) {
                shouldProcessGroup = true;
                belchertown_debug("Date Range UI: Processing " + groupName + " - matches URL parameter " + urlGraph);
            } else {
                belchertown_debug("Date Range UI: Skipping " + groupName + " - doesn't match URL parameter " + urlGraph);
            }
        } else {
            // FIXED: URL path-based detection
            var currentPath = window.location.pathname;
            var isHomePage = (currentPath === '/' || currentPath === '/index.html');
            var isGraphsSection = currentPath.includes('graphs');
            
            belchertown_debug("Date Range UI: URL path detection - currentPath: " + currentPath + ", isHomePage: " + isHomePage + ", isGraphsSection: " + isGraphsSection);
            
            if (isHomePage) {
                // HOMEPAGE (my.domain/): Only process the 'homepage' chart group
                if (groupName === 'homepage') {
                    shouldProcessGroup = true;
                    belchertown_debug("Date Range UI: Processing " + groupName + " - on homepage (path: " + currentPath + "), homepage group only");
                } else {
                    belchertown_debug("Date Range UI: Skipping " + groupName + " - on homepage (path: " + currentPath + "), only 'homepage' group should be processed");
                }
            } else if (isGraphsSection) {
                // GRAPHS SECTION (my.domain/graphs or my.domain/graphs/?graph=all): process all enabled groups
                shouldProcessGroup = true;
                if (urlGraph === 'all') {
                    belchertown_debug("Date Range UI: Processing " + groupName + " - on graphs section with ?graph=all");
                } else {
                    belchertown_debug("Date Range UI: Processing " + groupName + " - on main graphs page");
                }
            } else {
                // FALLBACK: Only process if there's evidence of charts on this page
                var hasChartEvidence = (
                    jQuery('.graph-outer').length > 0 ||
                    jQuery('.highcharts-container').length > 0 ||
                    jQuery('[class*="chart"]').length > 0 ||
                    jQuery('[id*="chart"]').length > 0
                );
                
                if (hasChartEvidence) {
                    shouldProcessGroup = true;
                    belchertown_debug("Date Range UI: Processing " + groupName + " - fallback found chart evidence on page");
                } else {
                    shouldProcessGroup = false;
                    belchertown_debug("Date Range UI: Skipping " + groupName + " - fallback found no chart evidence on page");
                }
            }
        }
        
        if (shouldProcessGroup) {
            (function(group) {
                // Use setTimeout to ensure chart containers exist before inserting dropdowns
                setTimeout(function() {
                    belchertown_debug("Date Range UI: Processing enabled group: " + group);
                    insertDateRangeDropdowns(group);
                }, 100);
            })(groupName);
        }
    }
    
    // Apply initial theme
    setTimeout(function() {
        applyDateRangeTheme();
    }, 200);
}

 /** Utility function to detect current page type and chart group
 * This helps with debugging and decision making
 */
function getPageContext() {
    var context = {
        pageName: pageName || 'unknown',
        graph: typeof graph !== 'undefined' ? graph : 'unknown',
        isAllView: false,
        isIndividualView: false,
        currentGroup: null
    };
    
    var currentPageGraph = context.pageName.replace('.html', '');
    if (currentPageGraph === 'unknown') {
        currentPageGraph = context.graph;
    }
    
    context.isAllView = (currentPageGraph === 'all' || currentPageGraph === 'graphs');
    
    // Check if we're on an individual chart group page
    var enabledGroups = getDateRangeEnabledGroups();
    for (var i = 0; i < enabledGroups.length; i++) {
        if (currentPageGraph === enabledGroups[i]) {
            context.isIndividualView = true;
            context.currentGroup = enabledGroups[i];
            break;
        }
    }
    
    return context;
}
