// Fix 2: updateAvailableMonths function
function updateAvailableMonths(groupName, selectedYear, monthSelectId) {
    var dateRangeInfo = getDateRangeInfo(groupName);
    if (!dateRangeInfo) return;
    
    // Find available months for the selected year
    var availableMonths = [];
    for (var i = 0; i < dateRangeInfo.monthlyRanges.length; i++) {
        if (dateRangeInfo.monthlyRanges[i].year === selectedYear) {
            availableMonths.push(dateRangeInfo.monthlyRanges[i].month);
        }
    }
    availableMonths.sort();
    
    var monthSelect = jQuery('#' + monthSelectId);
    
    // Enable/disable month options based on availability
    monthSelect.find('option').each(function() {
        var option = jQuery(this);
        var monthValue = option.val();
        
        if (monthValue === '') return; // Skip "Select Month" option
        
        if (availableMonths.indexOf(monthValue) !== -1) {
            option.prop('disabled', false).show();
        } else {
            option.prop('disabled', true).hide();
        }
    });
    
    // Reset month selection
    monthSelect.val('');
}

