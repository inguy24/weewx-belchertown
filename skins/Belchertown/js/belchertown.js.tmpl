 * but disappear in individual chart group view.
 */

function insertDateRangeDropdowns(groupName) {
    if (!isDateRangeEnabled(groupName)) {
        belchertown_debug("Date Range UI: Group " + groupName + " does not have date ranges enabled");
        return;
    }

    belchertown_debug("Date Range UI: Starting ENHANCED dropdown insertion for group: " + groupName);

    // Enhanced page context detection with multiple fallback methods
    var currentPageGraph = 'unknown';
    var detectionMethod = 'unknown';
    
    // Method 1: Check pageName variable
    if (typeof pageName !== 'undefined' && pageName) {
        currentPageGraph = pageName.replace('.html', '');
        detectionMethod = 'pageName';
    }
    // Method 2: Check graph variable  
    else if (typeof graph !== 'undefined' && graph) {
        currentPageGraph = graph;
        detectionMethod = 'graph_variable';
    }
    // Method 3: Check URL pathname
    else {
        var pathname = window.location.pathname;
        var pathParts = pathname.split('/');
        var lastPart = pathParts[pathParts.length - 1];
        if (lastPart && lastPart.includes('.html')) {
            currentPageGraph = lastPart.replace('.html', '');
            detectionMethod = 'url_pathname';
        }
        // Method 4: Check for specific page indicators in DOM
        else if (jQuery('.graph-outer-all').length > 0) {
            currentPageGraph = 'all';
            detectionMethod = 'dom_all_indicator';
        }
        else if (jQuery('.graph-outer').length > 0) {
            currentPageGraph = groupName; // Assume individual view
            detectionMethod = 'dom_individual_assumption';
        }
    }
    
    // IMPROVED: Smarter view context determination
    // Check if we're actually in individual view even if pageName says "graphs"
    var probableAllView = (currentPageGraph === 'all' || currentPageGraph === 'graphs');
    var probableIndividualView = (currentPageGraph === groupName || detectionMethod === 'dom_individual_assumption');
    
    // Smart detection: If pageName is "graphs" but no prefixed containers exist, we're in individual view
    var hasGroupPrefixedContainers = false;
    if (probableAllView) {
        hasGroupPrefixedContainers = jQuery('[id^="' + groupName + '_"]').length > 0;
        belchertown_debug("Date Range UI: Checking for group-prefixed containers (" + groupName + "_*): " + hasGroupPrefixedContainers);
    }
    
    // Final view determination with smart fallback
    var isAllView = probableAllView && hasGroupPrefixedContainers;
    var isIndividualView = probableIndividualView || (probableAllView && !hasGroupPrefixedContainers);
    
    belchertown_debug("Date Range UI: ENHANCED context detection:");
    belchertown_debug("  - currentPageGraph: " + currentPageGraph);
    belchertown_debug("  - detectionMethod: " + detectionMethod);
    belchertown_debug("  - probableAllView: " + probableAllView);
    belchertown_debug("  - hasGroupPrefixedContainers: " + hasGroupPrefixedContainers);
    belchertown_debug("  - FINAL isAllView: " + isAllView);
    belchertown_debug("  - FINAL isIndividualView: " + isIndividualView);

    var chartContainers = jQuery();
    var insertionTarget = null;
    var insertPosition = 'group-level';
    var containerDetectionMethod = 'none';

    if (isAllView) {
        belchertown_debug("Date Range UI: Processing ALL VIEW for group: " + groupName);
        
        // All view: containers are prefixed with groupName
        chartContainers = jQuery('[id^="' + groupName + '_"]');
        containerDetectionMethod = 'prefixed_containers';
        
        // Find the group container for insertion
        var groupOuterContainer = jQuery('.' + groupName + '_outer');
        if (groupOuterContainer.length > 0) {
            insertionTarget = groupOuterContainer.find('.graphpage-content').first();
            if (insertionTarget.length === 0) {
                insertionTarget = groupOuterContainer.first();
            }
            insertPosition = 'group-level';
        }
        
        belchertown_debug("Date Range UI: All view - found " + chartContainers.length + " containers with prefix: " + groupName + "_");
        
    } else if (isIndividualView || detectionMethod === 'dom_individual_assumption') {
        belchertown_debug("Date Range UI: Processing INDIVIDUAL VIEW for group: " + groupName);
        
        // Enhanced container detection for individual view with multiple strategies
        var strategies = [
            // Strategy 1: Look for chart containers without underscore (most common)
            function() {
                var candidates = jQuery('[id*="chart"]:not([id*="_"])');
                var validContainers = candidates.filter(function() {
                    var $el = jQuery(this);
                    return $el.is('div') && 
                        $el.closest('table').length === 0 && 
                        $el.is(':visible') &&
                        ($el.width() > 50 || $el.height() > 50);
                });
                if (validContainers.length > 0) {
                    containerDetectionMethod = 'validated_chart_no_underscore';
                    return validContainers;
                }
                return jQuery();
            },
            
            // Strategy 2: Look for original chart container IDs (before Highcharts renders)
            function() {
                var candidates = jQuery('#temp_test, #wind_test, #rain_test, #pressure_test, #humidity_test, #radiation_test');
                var validContainers = candidates.filter(function() {
                    var $el = jQuery(this);
                    return $el.is('div') && 
                        $el.closest('table').length === 0 && 
                        $el.is(':visible') &&
                        ($el.width() > 50 || $el.height() > 50);
                });
                if (validContainers.length > 0) {
                    containerDetectionMethod = 'validated_known_chart_ids';
                    return validContainers;
                }
                return jQuery();
            },
            
            // Strategy 3: Look for containers that match the group pattern but without prefix
            function() {
                var possibleIds = ['temp_test', 'wind_test', 'rain_test', 'pressure_test', 'humidity_test', 'radiation_test'];
                var candidates = jQuery();
                possibleIds.forEach(function(id) {
                    var element = jQuery('#' + id);
                    if (element.length > 0) {
                        candidates = candidates.add(element);
                    }
                });
                var validContainers = candidates.filter(function() {
                    var $el = jQuery(this);
                    return $el.is('div') && 
                        $el.closest('table').length === 0 && 
                        $el.is(':visible') &&
                        ($el.width() > 50 || $el.height() > 50);
                });
                if (validContainers.length > 0) {
                    containerDetectionMethod = 'validated_group_pattern_match';
                    return validContainers;
                }
                return jQuery();
            },
            
            // Strategy 4: Look within .graph-outer container
            function() {
                var graphOuter = jQuery('.graph-outer');
                if (graphOuter.length > 0) {
                    var candidates = graphOuter.find('[id*="chart"], [id*="Graph"], [id*="roseplt"], [id*="test"]');
                    var validContainers = candidates.filter(function() {
                        var $el = jQuery(this);
                        return $el.is('div') && 
                            $el.closest('table').length === 0 && 
                            $el.is(':visible') &&
                            ($el.width() > 50 || $el.height() > 50);
                    });
                    if (validContainers.length > 0) {
                        containerDetectionMethod = 'validated_graph_outer_search';
                        return validContainers;
                    }
                }
                return jQuery();
            },
            
            // Strategy 5: Look for any div with highcharts class (rendered charts) and find their original containers
            function() {
                var highchartsContainers = jQuery('.highcharts-container');
                var originalContainers = jQuery();
                highchartsContainers.each(function() {
                    var parent = jQuery(this).parent();
                    if (parent.attr('id') && !parent.attr('id').startsWith('highcharts-')) {
                        originalContainers = originalContainers.add(parent);
                    }
                });
                var validContainers = originalContainers.filter(function() {
                    var $el = jQuery(this);
                    return $el.is('div') && 
                        $el.closest('table').length === 0 && 
                        $el.is(':visible') &&
                        ($el.width() > 50 || $el.height() > 50);
                });
                if (validContainers.length > 0) {
                    containerDetectionMethod = 'validated_highcharts_original_containers';
                    return validContainers;
                }
                return jQuery();
            },
            
            // Strategy 6: Look for chart containers with validation
            function() {
                var patterns = ['[id*="temp"]', '[id*="rain"]', '[id*="wind"]', '[id*="pressure"]', '[id*="humidity"]', '[id*="test"]'];
                for (var i = 0; i < patterns.length; i++) {
                    var candidates = jQuery(patterns[i]);
                    var validContainers = candidates.filter(function() {
                        var $el = jQuery(this);
                        // Only accept divs that are:
                        // 1. Actually div elements (not table cells, spans, etc.)
                        // 2. Not inside tables 
                        // 3. Have reasonable dimensions for charts
                        // 4. Not hidden
                        return $el.is('div') && 
                            $el.closest('table').length === 0 && 
                            $el.is(':visible') &&
                            ($el.width() > 50 || $el.height() > 50);
                    });

                    // Debug message to show filtering results
                    if (candidates.length > 0) {
                        belchertown_debug("Date Range UI: Pattern " + patterns[i] + " found " + candidates.length + " candidates, " + validContainers.length + " valid containers");
                    }
                    
                    if (validContainers.length > 0) {
                        containerDetectionMethod = 'validated_pattern_' + patterns[i];
                        return validContainers;
                    }
                }
                return jQuery();
            }
        ];
        
        // Try each strategy until we find containers
        for (var i = 0; i < strategies.length; i++) {
            chartContainers = strategies[i]();
            if (chartContainers.length > 0) {
                break;
            }
        }
        
        // Enhanced insertion target detection for individual view
        var insertionStrategies = [
            // Strategy 1: Look for .graphpage-content
            function() {
                var target = jQuery('.graphpage-content').first(); 
                if (target.length > 0) return target;
                return null;
            },
            
            // Strategy 2: Look for .graph-outer
            function() {
                var target = jQuery('.graph-outer').first();
                if (target.length > 0) return target;
                return null;
            },
            
            // Strategy 3: Look for container of first chart
            function() {
                if (chartContainers.length > 0) {
                    var target = chartContainers.first().parent();
                    if (target.length > 0) return target;
                }
                return null;
            },
            
            // Strategy 4: Look for .site-inner or .wrap
            function() {
                var target = jQuery('.site-inner, .wrap').first();
                if (target.length > 0) return target;
                return null;
            }
        ];
        
        // Try each insertion strategy
        for (var i = 0; i < insertionStrategies.length; i++) {
            insertionTarget = insertionStrategies[i]();
            if (insertionTarget) {
                break;
            }
        }
        
        insertPosition = 'group-level';
        
        belchertown_debug("Date Range UI: Individual view - found " + chartContainers.length + " chart containers using method: " + containerDetectionMethod);
        
    } else {
        belchertown_debug("Date Range UI: UNKNOWN PAGE CONTEXT - attempting comprehensive fallback detection");
        
        // Comprehensive fallback: Try to find ANY chart containers using all strategies
        var allStrategies = [
            jQuery('[id*="chart"], [id*="Graph"], [id*="roseplt"]'),
            jQuery('[id*="temp"], [id*="wind"], [id*="rain"], [id*="pressure"], [id*="humidity"], [id*="test"]'), 
            jQuery('.highcharts-container').parent(),
            jQuery('#temp_test, #wind_test, #rain_test, #pressure_test, #humidity_test, #radiation_test')
        ];
        
        for (var i = 0; i < allStrategies.length; i++) {
            if (allStrategies[i].length > 0) {
                chartContainers = allStrategies[i];
                containerDetectionMethod = 'fallback_strategy_' + i;
                break;
            }
        }
        
        if (chartContainers.length > 0) {
            insertionTarget = chartContainers.first().parent();
            insertPosition = 'group-level';
            belchertown_debug("Date Range UI: Fallback found " + chartContainers.length + " containers using strategy " + containerDetectionMethod);
        } else {
            belchertown_debug("Date Range UI: No containers found with any method for group " + groupName + " (currentPage: " + currentPageGraph + ")");
            return;
        }
    }

    // Verify we found containers
    if (chartContainers.length === 0) {
        belchertown_debug("Date Range UI: ERROR - No chart containers found for group: " + groupName);
        belchertown_debug("Date Range UI: Available containers on page:");
        jQuery('[id*="chart"], [id*="Graph"], [id*="roseplt"]').each(function() {
            belchertown_debug("  - Found container: " + this.id);
        });
        return;
    }

    // Check if dropdowns already exist for this group to avoid duplicates
    var existingDropdowns = jQuery('.date-range-dropdowns-container[data-chart-group="' + groupName + '"]');
    if (existingDropdowns.length > 0) {
        belchertown_debug("Date Range UI: Dropdowns already exist for group: " + groupName + " (count: " + existingDropdowns.length + ")");
        return;
    }

    // Create and insert dropdowns using the enhanced system
    if (insertPosition === 'group-level' && insertionTarget && insertionTarget.length > 0) {
        var dropdownsHtml = createDateRangeDropdowns(groupName, groupName + '_group');
        if (dropdownsHtml) {
            // Try different insertion methods based on context
            if (isAllView) {
                insertionTarget.after(dropdownsHtml);
                belchertown_debug("Date Range UI: Added ALL VIEW group-level dropdowns for: " + groupName);
            } else {
                // For individual view, try prepending to insertion target
                insertionTarget.prepend(dropdownsHtml);
                belchertown_debug("Date Range UI: Added INDIVIDUAL VIEW group-level dropdowns for: " + groupName);
            }
        }
    } else {
        // Fallback: Insert dropdowns before each chart container
        belchertown_debug("Date Range UI: Using fallback per-chart insertion method");
        chartContainers.each(function() {
            var chartContainer = jQuery(this);
            var containerId = chartContainer.attr('id');
            
            // Skip if dropdown already exists for this container
            if (chartContainer.prev('.date-range-dropdowns-container').length > 0) {
                return;
            }

            var dropdownsHtml = createDateRangeDropdowns(groupName, containerId);
            if (dropdownsHtml) {
                chartContainer.before(dropdownsHtml);
                belchertown_debug("Date Range UI: Added chart-level dropdowns for container: " + containerId);
            }
        });
    }

    // Attach event handlers after inserting dropdowns
    attachDateRangeDropdownHandlers(groupName);
    
    belchertown_debug("Date Range UI: COMPLETED enhanced dropdown insertion for group: " + groupName);
    belchertown_debug("Date Range UI: Final summary:");
    belchertown_debug("  - Containers found: " + chartContainers.length + " (method: " + containerDetectionMethod + ")");
    belchertown_debug("  - Insertion target: " + (insertionTarget ? 'found' : 'none'));
    belchertown_debug("  - Dropdowns created: " + jQuery('.date-range-dropdowns-container[data-chart-group="' + groupName + '"]').length);
}

/**
 * Add auto-loading of default selection
 */
function autoLoadDefaultSelection(groupName) {
    // Check if we have stored default selection for this group
    if (window.dateRangeDefaults && window.dateRangeDefaults[groupName]) {
        var defaultSelection = window.dateRangeDefaults[groupName];
        
        if (defaultSelection.filename) {
            belchertown_debug("Date Range UI: Auto-loading default selection for " + groupName + ": " + defaultSelection.displayName);
            
            // Use existing chart loading mechanism with the default file
            var containerId = groupName + '_group';
            setTimeout(function() {
                handleDateRangeSelection(defaultSelection.filename, defaultSelection.displayName, groupName, containerId);
            }, 100);
        }
    }
}

/**
 * Enhanced event handler attachment for multiple dropdowns
 * REPLACES the existing attachDateRangeDropdownHandlers() function
 */
function attachDateRangeDropdownHandlers(groupName) {
    // Handle dropdown option clicks from all dropdown types
    jQuery('.date-range-option[data-group-name="' + groupName + '"]').off('click.daterange').on('click.daterange', function(e) {
        e.preventDefault();
        
        var $option = jQuery(this);
        var filename = $option.data('filename');
        var displayName = $option.data('display-name');
        var containerGroupName = $option.data('group-name');
        var containerId = $option.data('container-id');
        
        belchertown_debug("Date Range UI: Dropdown clicked - " + displayName + " (" + filename + ")");
        belchertown_debug("Date Range UI: Event data - group: " + containerGroupName + ", container: " + containerId);
        
        // Update the button text of the dropdown that was clicked
        var $dropdown = $option.closest('.dropdown');
        var $button = $dropdown.find('.dropdown-toggle');
        $button.contents().first()[0].textContent = displayName + ' ';
        
        handleDateRangeSelection(filename, displayName, containerGroupName, containerId);
    });

    belchertown_debug("Date Range UI: Attached event handlers for group: " + groupName);
    belchertown_debug("Date Range UI: Found " + jQuery('.date-range-option[data-group-name="' + groupName + '"]').length + " dropdown options to attach handlers to");
}

/**
 * Phase 4.5: Updated event handler for dropdown selections
 * REPLACE the existing handleDateRangeSelection() function
 */
function handleDateRangeSelection(filename, displayName, groupName, containerId) {
    belchertown_debug("Date Range UI: Selected " + displayName + " (" + filename + ") for " + containerId);
    
    // Cancel any previous chart load operations for this group
    cancelPreviousChartLoad(groupName);
    
    // Show loading indicator
    var loadingSelector = '[data-container-id="' + containerId + '"] .date-range-loading, [data-chart-group="' + groupName + '"] .date-range-loading';
    jQuery(loadingSelector).show();
    
    // Close all dropdowns in this container
    var containerSelector = '[data-container-id="' + containerId + '"] .dropdown-toggle, [data-chart-group="' + groupName + '"] .dropdown-toggle';
    jQuery(containerSelector).dropdown('toggle');
    
    // Load specific date range
    activeChartLoadOperations[groupName] = setTimeout(function() {
        loadChartWithDateRange(filename, containerId, groupName)
            .then(function() {
                jQuery(loadingSelector).hide();
                belchertown_debug("Date Range UI: Successfully loaded " + filename);
            })
            .catch(function(error) {
                jQuery(loadingSelector).hide();
                handleChartLoadError(error, groupName, containerId);
            });
    }, 100);
}

/**
 * Phase 4.6: Determine the correct showChart context
 * FIXED: Check URL parameters to detect individual graph view
 * 
 * @param {string} groupName - The chart group name
 * @returns {boolean} Whether to use prepend_renderTo
 */
function determineShowChartContext(groupName) {
    // Check page context to determine if we should use prepend_renderTo
    var currentPageGraph = 'unknown';
    
    // First check URL parameters (most reliable)
    var urlGraph = getURLvar('graph');
    if (urlGraph) {
        currentPageGraph = urlGraph;
        belchertown_debug("Date Range: URL parameter graph=" + urlGraph + " detected");
    } else if (typeof pageName !== 'undefined' && pageName) {
        currentPageGraph = pageName.replace('.html', '');
    } else if (typeof graph !== 'undefined' && graph) {
        currentPageGraph = graph;
    }
    
    // For individual graph pages, do NOT use prepend_renderTo
    if (currentPageGraph === groupName) {
        var usePrependRenderTo = false;
        belchertown_debug("Date Range: Individual graph page for " + groupName + ", using prepend_renderTo: " + usePrependRenderTo);
    } else {
        // For "all" or "graphs" pages, use prepend_renderTo
        var usePrependRenderTo = (currentPageGraph === 'all' || currentPageGraph === 'graphs');
        belchertown_debug("Date Range: Main graphs page (" + currentPageGraph + "), using prepend_renderTo: " + usePrependRenderTo);
    }
    
    return usePrependRenderTo;
}

/**
 * Helper function to handle chart loading errors
 */
function handleChartLoadError(error, groupName, containerId) {
    belchertown_debug("Date Range UI: Error loading chart - " + error.message);
    
    // Show error message
    var errorMessage = '<div class="alert alert-warning alert-dismissible" role="alert">' +
                      '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
                      '<span aria-hidden="true">&times;</span></button>' +
                      '<strong>Chart Load Error:</strong> Unable to load the selected date range. ' +
                      '<a href="#" class="retry-chart-load" data-group="' + groupName + '">Try again</a> or ' +
                      '<a href="#" class="load-all-data" data-group="' + groupName + '">show all data</a>.' +
                      '</div>';
    
    // Find the best place to show the error
    var errorContainer = jQuery('[data-chart-group="' + groupName + '"]').first();
    if (errorContainer.length === 0) {
        errorContainer = jQuery('.date-range-dropdowns-container').first();
    }
    
    if (errorContainer.length > 0) {
        errorContainer.before(errorMessage);
        
        // Add event handlers for error message actions
        jQuery('.retry-chart-load[data-group="' + groupName + '"]').click(function(e) {
            e.preventDefault();
            jQuery(this).closest('.alert').remove();
            // Could retry the last operation here
        });
        
        jQuery('.load-all-data[data-group="' + groupName + '"]').click(function(e) {
            e.preventDefault();
            jQuery(this).closest('.alert').remove();
            rollbackToAllData(groupName);
        });
        
        // Auto-remove error after 10 seconds
        setTimeout(function() {
            jQuery('.alert').remove();
        }, 10000);
    }
    
    // Reset button text on error
    setTimeout(function() {
        var $containers = jQuery('[data-container-id="' + containerId + '"] .dropdown-toggle, [data-chart-group="' + groupName + '"] .dropdown-toggle');
        $containers.each(function() {
            var $button = jQuery(this);
            var originalText = 'Recent Periods ';
            if ($button.attr('id') && $button.attr('id').indexOf('years') >= 0) {
                originalText = 'Years ';
            } else if ($button.attr('id') && $button.attr('id').indexOf('months') >= 0) {
                originalText = 'Months ';
            }
            $button.contents().first()[0].textContent = originalText;
        });
    }, 3000);
}

/**
 * Helper function to get a CSS selector for an element
 * FIXED: Handle DOMTokenList className in addition to string
 */
function getElementSelector(element) {
    if (element.id) {
        return '#' + element.id;
    }
    if (element.className) {
        // Fix: Handle both string and DOMTokenList className
        var classString;
        if (typeof element.className === 'string') {
            classString = element.className;
        } else {
            // DOMTokenList - convert to string  
            classString = String(element.className);
        }
        
        if (classString && classString.trim()) {
            var firstClass = classString.split(' ')[0];
            if (firstClass) {
                return '.' + firstClass;
            }
        }
    }
    return element.tagName.toLowerCase();
}

/**
 * Phase 4 REWRITE: Load chart with specific date range using container clearing approach
 * 
 * @param {string} filename - The JSON filename to load (e.g., "test_ranges_7d.json")
 * @param {string} containerId - The original chart container ID or dropdown container ID
 * @param {string} groupName - The chart group name (e.g., "test_ranges")
 * @returns {Promise} Promise that resolves when chart is loaded
 */
function loadChartWithDateRange(filename, containerId, groupName) {
    return new Promise(function(resolve, reject) {
        belchertown_debug("Date Range: Starting container clearing for file: " + filename + " for group: " + groupName);
        
        try {
            // Step 1: Clear existing charts for this group (but keep containers)
            clearChartsForGroup(groupName);
            
            // Step 2: Ensure required containers exist for the new chart
            ensureContainersExist(filename, groupName);
            
            // Step 3: Load new chart data using existing showChart() function
            var baseFilename = filename.replace('.json', ''); // Remove .json extension for showChart
            
            // Determine if we need prepend_renderTo based on page context
            var usePrependRenderTo = determineShowChartContext(groupName);
            
            belchertown_debug("Date Range: Calling showChart('" + baseFilename + "', " + usePrependRenderTo + ")");
            
            // Give the DOM a moment to settle after clearing and container creation
            setTimeout(function() {
                try {
                    showChart(baseFilename, usePrependRenderTo);
                    
                    // Wait for charts to render, then resolve
                    setTimeout(function() {
                        belchertown_debug("Date Range: ✅ Successfully loaded " + filename + " using container clearing");
                        resolve();
                    }, 1000);
                    
                } catch (error) {
                    belchertown_debug("Date Range: ❌ Error calling showChart - " + error.message);
                    reject(error);
                }
            }, 100);
            
        } catch (error) {
            belchertown_debug("Date Range: ❌ Exception in loadChartWithDateRange - " + error.message);
            reject(error);
        }
    });
}

/**
 * FIXED: Clear existing charts for a specific group before loading new date range
 * This prevents chart overlap and ensures clean transitions
 * 
 * @param {string} groupName - The chart group name
 */
function clearChartsForGroup(groupName) {
    belchertown_debug("Date Range: Clearing existing charts for group: " + groupName);
    
    try {
        // Determine if we're on main graphs page or individual page
        var usePrependRenderTo = determineShowChartContext(groupName);
        belchertown_debug("Date Range: DEBUG - usePrependRenderTo for " + groupName + " = " + usePrependRenderTo); // ADD THIS LINE
        belchertown_debug("Date Range: DEBUG - checking container: " + containerId + " against groupName: " + groupName);
        
        // Find and destroy all existing Highcharts instances
        if (typeof Highcharts !== 'undefined' && Highcharts.charts) {
            var destroyedCount = 0;
            
            for (var i = Highcharts.charts.length - 1; i >= 0; i--) {
                var chart = Highcharts.charts[i];
                if (chart && chart.renderTo && chart.renderTo.id) {
                    var containerId = chart.renderTo.id;
                    var belongsToGroup = false;
                    
                    if (usePrependRenderTo) {
                        // Main graphs page: only destroy charts that start with groupName_
                        if (containerId.indexOf(groupName + '_') === 0) {
                            belongsToGroup = true;
                        }
                    } else {
                        // Individual page: verify we're on the correct group's page
                        // Check URL parameter first (most reliable)
                        var urlGraph = getURLvar('graph');
                        var isCorrectGroupPage = false;
                        
                        if (urlGraph && urlGraph === groupName) {
                            isCorrectGroupPage = true;
                        } else if (typeof pageName !== 'undefined' && pageName === groupName + '.html') {
                            isCorrectGroupPage = true;
                        }
                        
                        // Only use broad pattern matching if we're on the correct group's page
                        if (isCorrectGroupPage && (containerId.indexOf('_test') >= 0 || 
                                                  containerId.indexOf('chart') >= 0 || 
                                                  containerId.indexOf('Graph') >= 0 ||
                                                  containerId.indexOf('roseplt') >= 0)) {
                            belongsToGroup = true;
                        }
                    }
                    
                    if (belongsToGroup) {
                        belchertown_debug("Date Range: Destroying chart in container: " + containerId);
                        chart.destroy();
                        // Clear the container but leave the div intact
                        jQuery('#' + containerId).empty();
                        destroyedCount++;
                    }
                }
            }
            
            belchertown_debug("Date Range: Destroyed " + destroyedCount + " existing charts for group: " + groupName);
        }
        
        // NEW: Remove leftover date range containers
        if (usePrependRenderTo) {
            // Remove containers that match date range patterns: groupName_dateRange_chartName
            var dateRangePattern = new RegExp('^' + groupName + '_(\\d+d|\\d{4}|\\d{4}-\\d{2})_');
            
            jQuery('[id^="' + groupName + '_"]').each(function() {
                var containerId = jQuery(this).attr('id');
                if (dateRangePattern.test(containerId)) {
                    belchertown_debug("Date Range: Removing leftover container: " + containerId);
                    jQuery(this).remove();
                }
            });
        }
        
    } catch (error) {
        belchertown_debug("Date Range: Error clearing charts - " + error.message);
        // Continue anyway - chart loading might still work
    }
}       

/**
 * Ensure required containers exist for date range charts
 * Creates missing containers by cloning existing ones with new IDs
 * 
 * @param {string} filename - The JSON filename (e.g., "test_ranges_2024-11.json")
 * @param {string} groupName - The chart group name
 */
function ensureContainersExist(filename, groupName) {
    belchertown_debug("Date Range: Ensuring containers exist for " + filename);
    
    var baseFilename = filename.replace('.json', ''); // e.g., "test_ranges_2024-11"
    var usePrependRenderTo = determineShowChartContext(groupName);
    
    if (usePrependRenderTo) {
        // Main graphs page: need containers like "test_ranges_2024-11_temp_test"
        var existingContainers = jQuery('[id^="' + groupName + '_"]');
        
        belchertown_debug("Date Range: Main graphs page - found " + existingContainers.length + " existing containers");
        
        existingContainers.each(function() {
            var $existingContainer = jQuery(this);
            var existingId = $existingContainer.attr('id');
            
            // Extract the chart part: test_ranges_temp_test -> temp_test
            var chartPart = existingId.replace(groupName + '_', '');
            
            // Construct expected new ID: test_ranges_2024-11_temp_test
            var expectedId = baseFilename + '_' + chartPart;
            
            // Check if expected container already exists
            if (!jQuery('#' + expectedId).length) {
                belchertown_debug("Date Range: Creating missing container: " + expectedId);
                
                // Clone the existing container with new ID
                var $newContainer = $existingContainer.clone();
                $newContainer.attr('id', expectedId);
                $newContainer.empty(); // Clear any existing content
                
                // Insert after the existing container
                $existingContainer.after($newContainer);
            } else {
                belchertown_debug("Date Range: Container " + expectedId + " already exists");
            }
        });
    } else {
        // Individual page: containers should already exist (temp_test, wind_test, etc.)
        // No additional containers needed since filename doesn't affect container ID
        belchertown_debug("Date Range: Individual page - containers should already exist as temp_test, wind_test, etc.");
        
        // Debug: Show what containers exist
        var existingContainers = jQuery('[id*="test"], [id*="chart"], [id*="Graph"]');
        belchertown_debug("Date Range: Found " + existingContainers.length + " potential chart containers:");
        existingContainers.each(function() {
            belchertown_debug("  - " + this.id);
        });
    }
}

