/**
 * Create monthly selector UI with dual dropdowns for year and month
 * @param {Array} monthlyFiles - Array of monthly file objects
 * @param {string} groupName - The chart group name
 * @param {string} containerId - The container ID
 * @returns {string} HTML string for monthly selector
 */
function createMonthlySelector(monthlyFiles, groupName, containerId) {
    // Extract unique years and sort them (newest first)
    const availableYears = [...new Set(monthlyFiles.map(f => f.year))].sort((a, b) => parseInt(b) - parseInt(a));
    
    const yearSelectId = `monthly-year-${containerId}`;
    const monthSelectId = `monthly-month-${containerId}`;
    
    let html = '<li class="monthly-selector-container">' +
                    '<div class="monthly-selector-wrapper">';
    
    // Year selector (only show if multiple years available)
    if (availableYears.length > 1) {
        html += '<div class="monthly-selector-group">' +
                            '<label class="monthly-selector-label">Year:</label>' +
                            '<select class="monthly-year-select" ' +
                                    'id="' + yearSelectId + '" ' +
                                    'data-group-name="' + groupName + '" ' +
                                    'data-container-id="' + containerId + '">';
        
        availableYears.forEach(year => {
            html += '<option value="' + year + '">' + year + '</option>';
        });
        
        html += '</select>' +
                        '</div>';
    } else if (availableYears.length === 1) {
        // Single year - show as fixed label
        html += '<div class="monthly-selector-group">' +
                            '<span class="monthly-fixed-year">' + availableYears[0] + '</span>' +
                            '<input type="hidden" id="' + yearSelectId + '" value="' + availableYears[0] + '" ' +
                                   'data-group-name="' + groupName + '" data-container-id="' + containerId + '">' +
                        '</div>';
    }
    
    // Month selector
    html += '<div class="monthly-selector-group">' +
                            '<label class="monthly-selector-label">Month:</label>' +
                            '<select class="monthly-month-select" ' +
                                    'id="' + monthSelectId + '" ' +
                                    'data-group-name="' + groupName + '" ' +
                                    'data-container-id="' + containerId + '">' +
                                '<option value="">Select Month</option>';
    
    // Add month options (will be populated dynamically based on year selection)
    const monthNames = [
        'January', 'February', 'March', 'April', 'May', 'June',
        'July', 'August', 'September', 'October', 'November', 'December'
    ];
    
    for (let i = 0; i < 12; i++) {
        const monthNum = (i + 1).toString().padStart(2, '0');
        html += '<option value="' + monthNum + '">' + monthNames[i] + '</option>';
    }
    
    html += '</select>' +
                        '</div>' +
                        '<div class="monthly-selector-group">' +
                            '<button type="button" class="btn btn-sm btn-primary monthly-go-button"' +
                                    ' data-group-name="' + groupName + '"' +
                                    ' data-container-id="' + containerId + '"' +
                                    ' data-year-select="' + yearSelectId + '"' +
                                    ' data-month-select="' + monthSelectId + '">' +
                                'Go' +
                            '</button>' +
                        '</div>' +
                    '</div>' +
                '</li>';
    
    return html;
}

/**
