/**
 * Create multiple horizontal dropdowns for date range selection
 * REPLACES the existing createDateRangeDropdown() function
 * @param {string} groupName - The chart group name (e.g., "test_ranges")
 * @param {string} containerId - The ID of the chart container div
 * @returns {string} HTML string for multiple dropdown components
 */
function createDateRangeDropdowns(groupName, containerId) {
    var dateRangeInfo = getDateRangeInfo(groupName);
    if (!dateRangeInfo) {
        belchertown_debug("Date Range UI: No date range info found for group: " + groupName);
        return '';
    }

    belchertown_debug("Date Range UI: Creating smart dropdowns for " + groupName + " with " + dateRangeInfo.allFiles.length + " options");

    // NEW: Container with label and responsive layout
    var dropdownsHtml = '<div class="date-range-dropdowns-container" data-chart-group="' + groupName + '" data-container-id="' + containerId + '">';
    
    // NEW: Add responsive label layout
    dropdownsHtml += '<div class="date-range-controls">';
    dropdownsHtml += '<div class="monthly-selector-label">Select time period:</div>';
    dropdownsHtml += '<div class="date-range-buttons-group">';
    
    // Determine defaults for auto-loading
    var defaultSelection = determineDefaultSelection(dateRangeInfo);
    
    // Smart dropdown selection based on available data granularity
    if (dateRangeInfo.monthlyRanges.length > 0) {
        belchertown_debug("Date Range UI: Monthly data detected - showing Recent Periods + Months dropdowns");
        
        if (dateRangeInfo.rollingRanges.length > 0) {
            dropdownsHtml += createRecentPeriodsDropdown(dateRangeInfo.rollingRanges, groupName, containerId, defaultSelection);
        }
        dropdownsHtml += createMonthsDropdown(dateRangeInfo.monthlyRanges, groupName, containerId, defaultSelection);
        
    } else if (dateRangeInfo.yearlyRanges.length > 0) {
        belchertown_debug("Date Range UI: Yearly data detected (no monthly) - showing Recent Periods + Years dropdowns");
        
        if (dateRangeInfo.rollingRanges.length > 0) {
            dropdownsHtml += createRecentPeriodsDropdown(dateRangeInfo.rollingRanges, groupName, containerId, defaultSelection);
        }
        dropdownsHtml += createYearsDropdown(dateRangeInfo.yearlyRanges, groupName, containerId, defaultSelection);
        
    } else if (dateRangeInfo.rollingRanges.length > 0) {
        belchertown_debug("Date Range UI: Only rolling periods detected - showing Recent Periods dropdown only");
        
        dropdownsHtml += createRecentPeriodsDropdown(dateRangeInfo.rollingRanges, groupName, containerId, defaultSelection);
    }
    
    // Close responsive containers
    dropdownsHtml += '</div>'; // date-range-buttons-group
    dropdownsHtml += '</div>'; // date-range-controls
    
    // Loading indicator (always present)
    dropdownsHtml += '<div class="date-range-loading" style="display: none;">';
    dropdownsHtml += '<i class="fa fa-spinner fa-spin"></i> Loading...';
    dropdownsHtml += '</div>';
    
    dropdownsHtml += '</div>'; // date-range-dropdowns-container
    
    // Store default selection for auto-loading
    dropdownsHtml += '<script>window.dateRangeDefaults = window.dateRangeDefaults || {}; window.dateRangeDefaults["' + groupName + '"] = ' + JSON.stringify(defaultSelection) + ';</script>';
    
    return dropdownsHtml;
}

/**
 * New function to determine default dropdown selection
 */
function determineDefaultSelection(dateRangeInfo) {
    var defaultSelection = {
        filename: null,
        displayName: null,
        type: null
    };
    
    // Priority: Rolling (shortest) > Monthly (latest) > Yearly (latest)
    if (dateRangeInfo.rollingRanges.length > 0) {
        // Sort by period duration and take shortest
        var sortedRolling = dateRangeInfo.rollingRanges.sort(function(a, b) {
            var aNum = parseInt(a.period.replace('d', ''));
            var bNum = parseInt(b.period.replace('d', ''));
            return aNum - bNum;
        });
        var shortest = sortedRolling[0];
        defaultSelection.filename = shortest.filename;
        defaultSelection.displayName = shortest.displayName;
        defaultSelection.type = 'rolling';
        
    } else if (dateRangeInfo.monthlyRanges.length > 0) {
        // Sort by year/month descending and take latest
        var sortedMonthly = dateRangeInfo.monthlyRanges.sort(function(a, b) {
            if (parseInt(b.year) !== parseInt(a.year)) {
                return parseInt(b.year) - parseInt(a.year);
            }
            return parseInt(b.month) - parseInt(a.month);
        });
        var latest = sortedMonthly[0];
        defaultSelection.filename = latest.filename;
        defaultSelection.displayName = latest.displayName;
        defaultSelection.type = 'monthly';
        
    } else if (dateRangeInfo.yearlyRanges.length > 0) {
        // Sort by year descending and take latest
        var sortedYearly = dateRangeInfo.yearlyRanges.sort(function(a, b) {
            return parseInt(b.year) - parseInt(a.year);
        });
        var latest = sortedYearly[0];
        defaultSelection.filename = latest.filename;
        defaultSelection.displayName = latest.displayName;
        defaultSelection.type = 'yearly';
    }
    
    return defaultSelection;
}

/**
 * UPDATED: Enhanced Recent Periods dropdown to always include "All Data" option
 * This ensures users can always get back to the full dataset view
 */
function createRecentPeriodsDropdown(rollingRanges, groupName, containerId, defaultSelection) {
