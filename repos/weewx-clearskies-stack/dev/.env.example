# Copy to .env and fill in real values. .env is gitignored.

# --- MariaDB service (used by the `mariadb` profile) ----------------------
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_DATABASE=weewx
MARIADB_USER=weewx
MARIADB_PASSWORD=change-me-weewx
# Host-side port to expose MariaDB on (loopback only).
MARIADB_HOST_PORT=3307

# --- Production capture (used by snapshot/capture.py) ---------------------
# Connection string to the production weewx archive DB. The capture script
# reflects whatever schema is live there. See snapshot/README.md.
CAPTURE_SOURCE_URL=mysql+pymysql://weewx:REDACTED@127.0.0.1:3306/weewx
# Bound the snapshot to a date window (epoch seconds, inclusive). Empty = all rows.
CAPTURE_START_EPOCH=
CAPTURE_END_EPOCH=
